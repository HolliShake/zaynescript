---
# We start with the standard LLVM style, then override the specifics.
BasedOnStyle: LLVM

# --- Indentation & Spacing ---
IndentWidth: 4
TabWidth: 4
UseTab: Never
ColumnLimit: 100

# --- Pointers & References ---
# Enforces "Environment* src" instead of "Environment *src"
PointerAlignment: Left

# --- Braces & Control Flow ---
# Uses the "One True Brace Style" (1TBS)
BreakBeforeBraces: Custom
BraceWrapping:
  AfterControlStatement: false # if (x) {
  AfterFunction: true          # int main()\n{
  AfterStruct: false           # struct Env {
  AfterEnum: false             # enum Opcodes {
  BeforeElse: false            # } else {
  IndentBraces: false

# Forces single-line "if" statements to break into multiple lines for readability
AllowShortIfStatementsOnASingleLine: false
AllowShortLoopsOnASingleLine: false
AllowShortBlocksOnASingleLine: false

# --- Switch Statements (Crucial for your VM loop!) ---
# Indents the 'case' inside the 'switch', and the code inside the 'case'
IndentCaseLabels: true
IndentCaseBlocks: true

# --- Alignment (The "Clean" Look) ---
# Automatically lines up consecutive variable assignments and declarations
# e.g., 
# int   x = 1;
# float y = 2.0;
AlignConsecutiveAssignments: true
AlignConsecutiveDeclarations: true

# --- Function Parameters ---
# If function arguments exceed the 100-column limit, drop them to new lines
# and align them neatly with the opening parenthesis.
AlignAfterOpenBracket: Align
BinPackArguments: false
BinPackParameters: false
---